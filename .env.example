# Application
APP_NAME=StockTracker API
APP_VERSION=0.0.1
DEBUG=true

# Logging
ENVIRONMENT=development
SERVICE_NAME=API
LOG_LEVEL=INFO
LOG_JSON=true
LOG_SQL=true

# Database
DATABASE_URL=postgresql+asyncpg://username:password@localhost:5432/database_name
DATABASE_POOL_PRE_PING=true
DATABASE_POOL_SIZE=5
DATABASE_MAX_OVERFLOW=10

# CORS
ALLOWED_ORIGINS=["http://localhost:3000"]

# Pagination
DEFAULT_PAGE_SIZE=10
MAX_PAGE_SIZE=100

# i18n
DEFAULT_LOCALE=en
SUPPORTED_LOCALES=["en", "vi"]

# OIDC Keycloak
OIDC_KEYCLOAK_SERVER_URL=https://keycloak.example.com
OIDC_KEYCLOAK_REALM=realm-name
OIDC_KEYCLOAK_CLIENT_ID=client-id
OIDC_KEYCLOAK_CLIENT_SECRET=client-secret
OIDC_KEYCLOAK_ADMIN_USERNAME=admin
OIDC_KEYCLOAK_ADMIN_PASSWORD=admin
OIDC_KEYCLOAK_VERIFY_TLS=true

# Context token
AUTH_CONTEXT_TOKEN_SECRET=secret
AUTH_CONTEXT_TOKEN_ALGORITHM=HS256
AUTH_CONTEXT_TOKEN_TTL_SECONDS=300
AUTH_CONTEXT_TOKEN_ISSUER=http://localhost:3000/api

# Redis
REDIS_ENABLED=true
REDIS_URL=redis://localhost:6379/0
REDIS_MAX_CONNECTIONS=10
REDIS_SOCKET_CONNECT_TIMEOUT=2
REDIS_SOCKET_TIMEOUT=2
REDIS_KEY_PREFIX=stocktracker
REDIS_KEY_SERVICE_PREFIX=api
REDIS_DEFAULT_TTL_SECONDS=300
REDIS_CIRCUIT_BREAKER_SECONDS=30

# RabbitMQ
RABBITMQ_ENABLED=true
RABBITMQ_URL=amqp://guest:guest@localhost:5672/
RABBITMQ_EXCHANGE_NAME=stocktracker
RABBITMQ_EXCHANGE_TYPE=topic
RABBITMQ_PREFETCH_COUNT=10
RABBITMQ_RECONNECT_DELAY_SECONDS=5
