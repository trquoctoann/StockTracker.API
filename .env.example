# Application
APP_NAME=StockTracker API
APP_VERSION=0.0.1
DEBUG=true

# Logging
ENVIRONMENT=development
SERVICE_NAME=API
LOG_LEVEL=INFO
LOG_JSON=true

# Database
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/stocktracker

# CORS
ALLOWED_ORIGINS=["http://localhost:3000"]

# Pagination
DEFAULT_PAGE_SIZE=10
MAX_PAGE_SIZE=100

# i18n
DEFAULT_LOCALE=en
SUPPORTED_LOCALES=["en", "vi"]
